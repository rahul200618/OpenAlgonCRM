  notes             String?
  v                 Int                       @default(0) @map("__v")
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  createdBy         String                    @db.Uuid
  updatedBy         String?                   @db.Uuid
  account           crm_Accounts              @relation(fields: [accountId], references: [id])
  assigned_currency Currency                  @relation(fields: [currency], references: [code])
  product           crm_Products              @relation(fields: [productId], references: [id])

  @@index([accountId])
  @@index([productId])
  @@index([status])
  @@index([accountId, productId])
}

model crm_OpportunityLineItems {
  id             String            @id @default(uuid()) @db.Uuid
  opportunityId  String            @db.Uuid
  productId      String?           @db.Uuid
  name           String
  sku            String?
  description    String?
  quantity       Int               @default(1)
  unit_price     Decimal           @db.Decimal(18, 2)
  discount_type  crm_Discount_Type @default(PERCENTAGE)
  discount_value Decimal           @default(0) @db.Decimal(18, 2)
  line_total     Decimal           @db.Decimal(18, 2)
  currency       String            @db.VarChar(3)
  sort_order     Int               @default(0)
  v              Int               @default(0) @map("__v")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  createdBy      String            @db.Uuid
  updatedBy      String?           @db.Uuid
  opportunity    crm_Opportunities @relation(fields: [opportunityId], references: [id])
  product        crm_Products?     @relation(fields: [productId], references: [id])

  @@index([opportunityId])
  @@index([productId])
}

model crm_ContractLineItems {
  id             String            @id @default(uuid()) @db.Uuid
  contractId     String            @db.Uuid
  productId      String?           @db.Uuid
  name           String
  sku            String?
  description    String?
  quantity       Int               @default(1)
  unit_price     Decimal           @db.Decimal(18, 2)
  discount_type  crm_Discount_Type @default(PERCENTAGE)
  discount_value Decimal           @default(0) @db.Decimal(18, 2)
  line_total     Decimal           @db.Decimal(18, 2)
  currency       String            @db.VarChar(3)
  sort_order     Int               @default(0)
  v              Int               @default(0) @map("__v")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  createdBy      String            @db.Uuid
  updatedBy      String?           @db.Uuid
  contract       crm_Contracts     @relation(fields: [contractId], references: [id])
  product        crm_Products?     @relation(fields: [productId], references: [id])

  @@index([contractId])
  @@index([productId])
}

model Invoices {
  id                String                   @id @default(uuid()) @db.Uuid
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  createdBy         String                   @db.Uuid
  type              Invoice_Type             @default(INVOICE)
  status            Invoice_Status           @default(DRAFT)
  number            String?
  numberOverridden  Boolean                  @default(false)
  seriesId          String?                  @db.Uuid
  accountId         String                   @db.Uuid
  billingSnapshot   Json?
  issueDate         DateTime?
  taxableSupplyDate DateTime?
  dueDate           DateTime?
  currency          String                   @db.VarChar(3)
  baseCurrency      String?                  @db.VarChar(3)
  fxRateToBase      Decimal?                 @db.Decimal(18, 8)
  subtotal          Decimal                  @default(0) @db.Decimal(14, 2)
  discountTotal     Decimal                  @default(0) @db.Decimal(14, 2)
  vatTotal          Decimal                  @default(0) @db.Decimal(14, 2)
  grandTotal        Decimal                  @default(0) @db.Decimal(14, 2)
  paidTotal         Decimal                  @default(0) @db.Decimal(14, 2)
  balanceDue        Decimal                  @default(0) @db.Decimal(14, 2)
  bankName          String?
  bankAccount       String?
  iban              String?
  swift             String?
  variableSymbol    String?
  publicNotes       String?
  internalNotes     String?
  originalInvoiceId String?                  @db.Uuid
  pdfStorageKey     String?
  pdfGeneratedAt    DateTime?
  searchVector      Unsupported("tsvector")? @map("search_vector")
  organization_id   String?                  @db.Uuid
  activity          Invoice_Activity[]
  attachments       Invoice_Attachments[]
  lineItems         Invoice_LineItems[]
  payments          Invoice_Payments[]
  account           crm_Accounts             @relation(fields: [accountId], references: [id])
  createdByUser     Users                    @relation("InvoiceCreatedBy", fields: [createdBy], references: [id])
  currencyRef       Currency                 @relation("InvoiceCurrency", fields: [currency], references: [code])
  organization      Organization?            @relation(fields: [organization_id], references: [id])
  originalInvoice   Invoices?                @relation("CreditNoteOf", fields: [originalInvoiceId], references: [id])
  creditNotes       Invoices[]               @relation("CreditNoteOf")
  series            Invoice_Series?          @relation(fields: [seriesId], references: [id])

  @@unique([seriesId, number])
  @@index([accountId])
  @@index([status])
  @@index([issueDate])
  @@index([dueDate])
  @@index([createdBy])
  @@index([originalInvoiceId])
  @@index([organization_id])
}

model Invoice_LineItems {
  id              String            @id @default(uuid()) @db.Uuid
  invoiceId       String            @db.Uuid
  position        Int
  productId       String?           @db.Uuid
  description     String
  quantity        Decimal           @db.Decimal(14, 4)
  unitPrice       Decimal           @db.Decimal(14, 4)
  discountPercent Decimal           @default(0) @db.Decimal(5, 2)
  taxRateId       String?           @db.Uuid
  taxRateSnapshot Decimal?          @db.Decimal(5, 2)
  lineSubtotal    Decimal           @db.Decimal(14, 2)
  lineVat         Decimal           @db.Decimal(14, 2)
  lineTotal       Decimal           @db.Decimal(14, 2)
  invoice         Invoices          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product         crm_Products?     @relation(fields: [productId], references: [id])
  taxRate         Invoice_TaxRates? @relation(fields: [taxRateId], references: [id])

  @@index([invoiceId])
  @@index([productId])
  @@index([taxRateId])
}

model Invoice_Payments {
  id            String   @id @default(uuid()) @db.Uuid
  invoiceId     String   @db.Uuid
  paidAt        DateTime
  amount        Decimal  @db.Decimal(14, 2)
  method        String?
  reference     String?
  note          String?
  createdBy     String   @db.Uuid
  createdAt     DateTime @default(now())
  createdByUser Users    @relation("InvoicePaymentCreatedBy", fields: [createdBy], references: [id])
  invoice       Invoices @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Invoice_Attachments {
  id             String   @id @default(uuid()) @db.Uuid
  invoiceId      String   @db.Uuid
  storageKey     String
  filename       String
  mimeType       String
  size           Int
  uploadedBy     String   @db.Uuid
  uploadedAt     DateTime @default(now())
  isPrimaryPdf   Boolean  @default(false)
  invoice        Invoices @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  uploadedByUser Users    @relation("InvoiceAttachmentUploadedBy", fields: [uploadedBy], references: [id])

  @@index([invoiceId])
}

model Invoice_Activity {
  id        String   @id @default(uuid()) @db.Uuid
  invoiceId String   @db.Uuid
  actorId   String   @db.Uuid
  action    String
  meta      Json?
  createdAt DateTime @default(now())
  actor     Users    @relation("InvoiceActivityActor", fields: [actorId], references: [id])
  invoice   Invoices @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Invoice_TaxRates {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  rate               Decimal             @db.Decimal(5, 2)
  isDefault          Boolean             @default(false)
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  lineItems          Invoice_LineItems[]
  defaultForSettings Invoice_Settings[]
}

model Invoice_Series {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  prefixTemplate     String
  resetPolicy        String             @default("YEARLY")
  currentYear        Int?
  counter            Int                @default(0)
  isDefault          Boolean            @default(false)
  active             Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  defaultForSettings Invoice_Settings[]
  invoices           Invoices[]
}

model Invoice_Settings {
  id               String            @id @default(uuid()) @db.Uuid
  baseCurrency     String            @db.VarChar(3)
  defaultSeriesId  String?           @db.Uuid
  defaultTaxRateId String?           @db.Uuid
  defaultDueDays   Int               @default(14)
  bankName         String?
  bankAccount      String?
  iban             String?
  swift            String?
  footerText       String?
  updatedAt        DateTime          @updatedAt
  companyName      String?
  companyAddress   String?
  companyCity      String?
  companyZip       String?
  companyCountry   String?
  companyVatId     String?
  companyTaxId     String?
  companyRegNo     String?
  companyEmail     String?
  companyPhone     String?
  companyWebsite   String?
  defaultSeries    Invoice_Series?   @relation(fields: [defaultSeriesId], references: [id])
  defaultTaxRate   Invoice_TaxRates? @relation(fields: [defaultTaxRateId], references: [id])
}

model Organization {
  id            String              @id @default(uuid()) @db.Uuid
  name          String
  plan          String              @default("free")
  status        String              @default("active")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  boards        Boards[]
  invoices      Invoices[]
  tasks         Tasks[]
  users         Users[]
  accounts      crm_Accounts[]
  contacts      crm_Contacts[]
  leads         crm_Leads[]
  opportunities crm_Opportunities[]
  campaigns     crm_campaigns[]

  // Stripe Billing
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  invites OrganizationInvite[]

  @@index([status])
  @@index([createdAt])
}

model OrganizationInvite {
  id             String       @id @default(uuid()) @db.Uuid
  email          String? // Optional: If you want to restrict the invite to a specific email
  token          String       @unique
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([token])
}

model WebhookLog {
  id        String   @id @default(uuid()) @db.Uuid
  source    String
  payload   Json
  status    String   @default("received")
  leadId    String?  @db.Uuid
  error     String?
  createdAt DateTime @default(now())

  @@index([source])
  @@index([status])
  @@index([createdAt])
  @@index([leadId])
}

model LeadAssignment {
  id         String    @id @default(uuid()) @db.Uuid
  leadId     String    @db.Uuid
  assignedTo String    @db.Uuid
  assignedBy String?   @db.Uuid
  strategy   String    @default("manual")
  createdAt  DateTime  @default(now())
  lead       crm_Leads @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([assignedTo])
  @@index([createdAt])
}

model Followup {
  id           String    @id @default(uuid()) @db.Uuid
  leadId       String    @db.Uuid
  assignedUser String    @db.Uuid
  followupDate DateTime
  note         String?
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lead         crm_Leads @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([assignedUser])
  @@index([followupDate])
  @@index([status])
}

model FeatureFlag {
  key         String   @id
  label       String
  description String?
  enabled     Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

