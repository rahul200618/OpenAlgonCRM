generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model crm_Accounts {
  id                   String                   @id @default(uuid()) @db.Uuid
  v                    Int                      @map("__v")
  createdAt            DateTime                 @default(now())
  createdBy            String?                  @db.Uuid
  updatedAt            DateTime?                @updatedAt
  updatedBy            String?                  @db.Uuid
  annual_revenue       String?
  assigned_to          String?                  @db.Uuid
  billing_city         String?
  billing_country      String?
  billing_postal_code  String?
  billing_state        String?
  billing_street       String?
  company_id           String?
  description          String?
  email                String?
  employees            String?
  fax                  String?
  industry             String?                  @db.Uuid
  member_of            String?
  name                 String
  office_phone         String?
  shipping_city        String?
  shipping_country     String?
  shipping_postal_code String?
  shipping_state       String?
  shipping_street      String?
  status               String?                  @default("Inactive")
  type                 String?                  @default("Customer")
  vat                  String?
  website              String?
  deletedAt            DateTime?
  deletedBy            String?                  @db.Uuid
  organization_id      String?                  @db.Uuid
  watchers             AccountWatchers[]
  documents            DocumentsToAccounts[]
  emails               EmailsToAccounts[]
  invoices             Invoices[]
  accountProducts      crm_AccountProducts[]
  assigned_to_user     Users?                   @relation("AccountAssignedTo", fields: [assigned_to], references: [id])
  industry_type        crm_Industry_Type?       @relation(fields: [industry], references: [id])
  organization         Organization?            @relation(fields: [organization_id], references: [id])
  crm_accounts_tasks   crm_Accounts_Tasks[]
  contacts             crm_Contacts[]
  contracts            crm_Contracts[]
  embedding            crm_Embeddings_Accounts?
  leads                crm_Leads[]
  opportunities        crm_Opportunities[]
  converted_targets    crm_Targets[]            @relation("target_converted_account")

  @@index([assigned_to])
  @@index([industry])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([organization_id])
}

model crm_Leads {
  id                String                @id @default(uuid()) @db.Uuid
  v                 Int                   @default(0) @map("__v")
  createdAt         DateTime?             @default(now())
  createdBy         String?               @db.Uuid
  updatedAt         DateTime?             @updatedAt
  updatedBy         String?               @db.Uuid
  firstName         String?
  lastName          String
  company           String?
  jobTitle          String?
  email             String?
  phone             String?
  description       String?
  refered_by        String?
  campaign          String?
  assigned_to       String?               @db.Uuid
  accountsIDs       String?               @db.Uuid
  lead_source_id    String?               @db.Uuid
  lead_status_id    String?               @db.Uuid
  lead_type_id      String?               @db.Uuid
  deletedAt         DateTime?
  deletedBy         String?               @db.Uuid
  channel           String?               @default("manual")
  organization_id   String?               @db.Uuid
  whatsapp_number   String?
  documents         DocumentsToLeads[]
  followups         Followup[]
  assignments       LeadAssignment[]
  embedding         crm_Embeddings_Leads?
  assigned_accounts crm_Accounts?         @relation(fields: [accountsIDs], references: [id])
  assigned_to_user  Users?                @relation("LeadAssignedTo", fields: [assigned_to], references: [id])
  lead_source       crm_Lead_Sources?     @relation("lead_source_relation", fields: [lead_source_id], references: [id])
  lead_status       crm_Lead_Statuses?    @relation("lead_status_relation", fields: [lead_status_id], references: [id])
  lead_type         crm_Lead_Types?       @relation("lead_type_relation", fields: [lead_type_id], references: [id])
  organization      Organization?         @relation(fields: [organization_id], references: [id])

  @@index([assigned_to])
  @@index([accountsIDs])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([lead_source_id])
  @@index([lead_status_id])
  @@index([lead_type_id])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([organization_id])
  @@index([channel])
}

model crm_Contact_Enrichment {
  id                String                @id @default(uuid()) @db.Uuid
  contactId         String                @db.Uuid
  status            crm_Enrichment_Status @default(PENDING)
  fields            String[]
  result            Json?
  error             String?
  triggeredBy       String?               @db.Uuid
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  contact           crm_Contacts          @relation(fields: [contactId], references: [id])
  triggered_by_user Users?                @relation("enrichment_triggered_by", fields: [triggeredBy], references: [id])

  @@index([contactId])
  @@index([status])
  @@index([createdAt])
  @@index([triggeredBy])
}

model crm_Target_Enrichment {
  id                String                @id @default(uuid()) @db.Uuid
  targetId          String                @db.Uuid
  status            crm_Enrichment_Status @default(PENDING)
  fields            String[]
  result            Json?
  error             String?
  triggeredBy       String?               @db.Uuid
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  target            crm_Targets           @relation(fields: [targetId], references: [id])
  triggered_by_user Users?                @relation("target_enrichment_triggered_by", fields: [triggeredBy], references: [id])

  @@index([targetId])
  @@index([status])
  @@index([createdAt])
  @@index([triggeredBy])
}

model crm_Target_Contact {
  id           String                @id @default(uuid()) @db.Uuid
  targetId     String                @db.Uuid
  contactId    String?               @db.Uuid
  name         String?
  email        String?
  title        String?
  phone        String?
  linkedinUrl  String?
  source       String                @default("manual")
  enrichStatus crm_Enrichment_Status @default(PENDING)
  enrichedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  contact      crm_Contacts?         @relation("target_contact_link", fields: [contactId], references: [id])
  target       crm_Targets           @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([targetId, email])
  @@unique([targetId, linkedinUrl])
  @@index([targetId])
  @@index([enrichStatus])
}

model crm_Opportunities {
  id                   String                          @id @default(uuid()) @db.Uuid
  v                    Int                             @default(0) @map("__v")
  account              String?                         @db.Uuid
  assigned_to          String?                         @db.Uuid
  budget               Decimal                         @default(0) @db.Decimal(18, 2)
  campaign             String?                         @db.Uuid
  close_date           DateTime?
  contact              String?                         @db.Uuid
  createdBy            String?                         @db.Uuid
  created_on           DateTime?                       @default(now())
  createdAt            DateTime                        @default(now())
  last_activity        DateTime?
  updatedAt            DateTime?                       @updatedAt
  updatedBy            String?                         @db.Uuid
  last_activity_by     String?                         @db.Uuid
  currency             String?                         @db.VarChar(3)
  description          String?
  expected_revenue     Decimal                         @default(0) @db.Decimal(18, 2)
  name                 String?
  next_step            String?
  sales_stage          String?                         @db.Uuid
  type                 String?                         @db.Uuid
  status               crm_Opportunity_Status?         @default(ACTIVE)
  deletedAt            DateTime?
  deletedBy            String?                         @db.Uuid
  snapshot_rate        Decimal?                        @db.Decimal(18, 8)
  organization_id      String?                         @db.Uuid
  contacts             ContactsToOpportunities[]
  documents            DocumentsToOpportunities[]
  embedding            crm_Embeddings_Opportunities?
  assigned_account     crm_Accounts?                   @relation(fields: [account], references: [id])
  assigned_to_user     Users?                          @relation("assigned_to_user_relation", fields: [assigned_to], references: [id])
  assigned_campaings   crm_campaigns?                  @relation(fields: [campaign], references: [id])
  created_by_user      Users?                          @relation("created_by_user_relation", fields: [createdBy], references: [id])
  assigned_currency    Currency?                       @relation(fields: [currency], references: [code])
  organization         Organization?                   @relation(fields: [organization_id], references: [id])
  assigned_sales_stage crm_Opportunities_Sales_Stages? @relation("assinged_sales_stage", fields: [sales_stage], references: [id])
  assigned_type        crm_Opportunities_Type?         @relation(fields: [type], references: [id])
  lineItems            crm_OpportunityLineItems[]

  @@index([account])
  @@index([assigned_to])
  @@index([campaign])
  @@index([contact])
  @@index([createdBy])
  @@index([sales_stage])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([close_date])
  @@index([status, sales_stage])
  @@index([deletedAt])
  @@index([organization_id])
}

model crm_campaigns {
  id              String                  @id @default(uuid()) @db.Uuid
  v               Int                     @map("__v")
  name            String
  description     String?
  status          String?
  template_id     String?                 @db.Uuid
  from_name       String?
  reply_to        String?
  scheduled_at    DateTime?
  sent_at         DateTime?
  created_by      String?                 @db.Uuid
  created_on      DateTime?               @default(now())
  updatedAt       DateTime?               @updatedAt
  deletedAt       DateTime?
  deletedBy       String?                 @db.Uuid
  organization_id String?                 @db.Uuid
  target_lists    CampaignToTargetLists[]
  opportunities   crm_Opportunities[]
  sends           crm_campaign_sends[]
  steps           crm_campaign_steps[]
  created_by_user Users?                  @relation("created_campaigns", fields: [created_by], references: [id])
  organization    Organization?           @relation(fields: [organization_id], references: [id])
  template        crm_campaign_templates? @relation("CampaignTemplate", fields: [template_id], references: [id])

  @@index([deletedAt])
  @@index([organization_id])
}

model crm_campaign_templates {
  id              String               @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  subject_default String?
  content_html    String
  content_json    Json
  created_by      String?              @db.Uuid
  created_on      DateTime?            @default(now())
  updatedAt       DateTime?            @updatedAt
  deletedAt       DateTime?
  deletedBy       String?              @db.Uuid
  steps           crm_campaign_steps[]
  created_by_user Users?               @relation("created_campaign_templates", fields: [created_by], references: [id])
  campaigns       crm_campaigns[]      @relation("CampaignTemplate")

  @@index([created_by])
  @@index([deletedAt])
}

model crm_campaign_steps {
  id           String                 @id @default(uuid()) @db.Uuid
  campaign_id  String                 @db.Uuid
  order        Int
  template_id  String                 @db.Uuid
  subject      String
  delay_days   Int                    @default(0)
  send_to      String                 @default("all")
  scheduled_at DateTime?
  sent_at      DateTime?
  sends        crm_campaign_sends[]
  campaign     crm_campaigns          @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  template     crm_campaign_templates @relation(fields: [template_id], references: [id])

  @@unique([campaign_id, order])
  @@index([campaign_id])
  @@index([scheduled_at])
}

model CampaignToTargetLists {
  campaign_id    String          @db.Uuid
  target_list_id String          @db.Uuid
  campaign       crm_campaigns   @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  target_list    crm_TargetLists @relation(fields: [target_list_id], references: [id], onDelete: Cascade)

  @@id([campaign_id, target_list_id])
}

model crm_campaign_sends {
  id                String             @id @default(uuid()) @db.Uuid
  campaign_id       String             @db.Uuid
  step_id           String             @db.Uuid
  target_id         String             @db.Uuid
  email             String
  status            String             @default("queued")
  resend_message_id String?
  unsubscribe_token String             @unique @default(uuid())
  opened_at         DateTime?
  clicked_at        DateTime?
  unsubscribed_at   DateTime?
  error_message     String?
  sent_at           DateTime?
  campaign          crm_campaigns      @relation(fields: [campaign_id], references: [id])
  step              crm_campaign_steps @relation(fields: [step_id], references: [id])
  target            crm_Targets        @relation(fields: [target_id], references: [id])

  @@unique([step_id, target_id])
  @@index([campaign_id])
  @@index([step_id, target_id])
  @@index([resend_message_id])
  @@index([status])
  @@index([unsubscribe_token])
}

model crm_Opportunities_Sales_Stages {
  id                                 String              @id @default(uuid()) @db.Uuid
  v                                  Int                 @default(0) @map("__v")
  name                               String
  probability                        Int?
  order                              Int?
  assigned_opportunities_sales_stage crm_Opportunities[] @relation("assinged_sales_stage")
}

model crm_Opportunities_Type {
  id                     String              @id @default(uuid()) @db.Uuid
  v                      Int                 @default(0) @map("__v")
  name                   String
  order                  Int?
  assigned_opportunities crm_Opportunities[]
}

model crm_Contact_Types {
  id       String         @id @default(uuid()) @db.Uuid
  v        Int            @default(0) @map("__v")
  name     String         @unique
  contacts crm_Contacts[]

  @@index([name])
}

model crm_Lead_Sources {
  id    String      @id @default(uuid()) @db.Uuid
  v     Int         @default(0) @map("__v")
  name  String      @unique
  leads crm_Leads[] @relation("lead_source_relation")

  @@index([name])
}

model crm_Lead_Statuses {
  id    String      @id @default(uuid()) @db.Uuid
  v     Int         @default(0) @map("__v")
  name  String      @unique
  leads crm_Leads[] @relation("lead_status_relation")

  @@index([name])
}

model crm_Lead_Types {
  id    String      @id @default(uuid()) @db.Uuid
  v     Int         @default(0) @map("__v")
  name  String      @unique
  leads crm_Leads[] @relation("lead_type_relation")

  @@index([name])
}

model crm_Contacts {
  id                   String                    @id @default(uuid()) @db.Uuid
  v                    Int                       @default(0) @map("__v")
  account              String?                   @db.Uuid
  assigned_to          String?                   @db.Uuid
  birthday             String?
  createdBy            String?                   @db.Uuid
  created_on           DateTime?                 @default(now())
  cratedAt             DateTime?                 @default(now())
  last_activity        DateTime?                 @default(now())
  updatedAt            DateTime?                 @updatedAt
  updatedBy            String?                   @db.Uuid
  last_activity_by     String?                   @db.Uuid
  description          String?
  email                String?
  personal_email       String?
  first_name           String?
  last_name            String
  office_phone         String?
  mobile_phone         String?
  website              String?
  position             String?
  status               Boolean                   @default(true)
  social_twitter       String?
  social_facebook      String?
  social_linkedin      String?
  social_skype         String?
  social_instagram     String?
  social_youtube       String?
  social_tiktok        String?
  tags                 String[]
  notes                String[]
  accountsIDs          String?                   @db.Uuid
  contact_type_id      String?                   @db.Uuid
  deletedAt            DateTime?
  deletedBy            String?                   @db.Uuid
  organization_id      String?                   @db.Uuid
  opportunities        ContactsToOpportunities[]
  documents            DocumentsToContacts[]
  emails               EmailsToContacts[]
  enrichments          crm_Contact_Enrichment[]
  assigned_accounts    crm_Accounts?             @relation(fields: [accountsIDs], references: [id])
  assigned_to_user     Users?                    @relation("assigned_contacts", fields: [assigned_to], references: [id])
  contact_type         crm_Contact_Types?        @relation(fields: [contact_type_id], references: [id])
  crate_by_user        Users?                    @relation("created_contacts", fields: [createdBy], references: [id])
  organization         Organization?             @relation(fields: [organization_id], references: [id])
  embedding            crm_Embeddings_Contacts?
  target_contact_links crm_Target_Contact[]      @relation("target_contact_link")
  converted_targets    crm_Targets[]             @relation("target_converted_contact")

  @@index([assigned_to])
  @@index([accountsIDs])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([status])
  @@index([contact_type_id])
  @@index([cratedAt])
  @@index([last_activity])
  @@index([deletedAt])
  @@index([organization_id])
}

model crm_Contracts {
  id                  String                  @id @default(uuid()) @db.Uuid
  v                   Int                     @map("__v")
  title               String
  value               Decimal                 @db.Decimal(18, 2)
  startDate           DateTime?               @default(now())
  endDate             DateTime?
  renewalReminderDate DateTime?
  customerSignedDate  DateTime?
  companySignedDate   DateTime?
  description         String?
  account             String?                 @db.Uuid
  assigned_to         String?                 @db.Uuid
  createdAt           DateTime?               @default(now())
  createdBy           String?                 @db.Uuid
  updatedAt           DateTime?               @updatedAt
  updatedBy           String?                 @db.Uuid
  status              crm_Contracts_Status    @default(NOTSTARTED)
  type                String?
  deletedAt           DateTime?
  deletedBy           String?                 @db.Uuid
  currency            String?                 @db.VarChar(3)
  snapshot_rate       Decimal?                @db.Decimal(18, 8)
  lineItems           crm_ContractLineItems[]
  assigned_account    crm_Accounts?           @relation(fields: [account], references: [id])
  assigned_to_user    Users?                  @relation(fields: [assigned_to], references: [id])
  assigned_currency   Currency?               @relation(fields: [currency], references: [code])

  @@index([account])
  @@index([assigned_to])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
  @@index([startDate, endDate])
  @@index([deletedAt])
}

model Currency {
  code            String                @id @db.VarChar(3)
  name            String
  symbol          String                @db.VarChar(5)
  isEnabled       Boolean               @default(true)
  isDefault       Boolean               @default(false)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  ratesFrom       ExchangeRate[]        @relation("rate_from")
  ratesTo         ExchangeRate[]        @relation("rate_to")
  invoices        Invoices[]            @relation("InvoiceCurrency")
  accountProducts crm_AccountProducts[]
  contracts       crm_Contracts[]
  opportunities   crm_Opportunities[]
  products        crm_Products[]
}

model ExchangeRate {
  id            String             @id @default(uuid()) @db.Uuid
  fromCurrency  String             @db.VarChar(3)
  toCurrency    String             @db.VarChar(3)
  rate          Decimal            @db.Decimal(18, 8)
  source        ExchangeRateSource @default(MANUAL)
  effectiveDate DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  from          Currency           @relation("rate_from", fields: [fromCurrency], references: [code])
  to            Currency           @relation("rate_to", fields: [toCurrency], references: [code])

  @@unique([fromCurrency, toCurrency])
  @@index([fromCurrency])
  @@index([toCurrency])
}

model crm_SystemSettings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model crm_Activities {
  id              String              @id @default(uuid()) @db.Uuid
  type            crm_Activity_Type
  title           String
  description     String?
  date            DateTime
  duration        Int?
  outcome         String?
  status          crm_Activity_Status @default(scheduled)
  metadata        Json?
  createdBy       String?             @db.Uuid
  updatedBy       String?             @db.Uuid
  createdAt       DateTime            @default(now())
  updatedAt       DateTime?           @updatedAt
  deletedAt       DateTime?
  deletedBy       String?             @db.Uuid
  created_by_user Users?              @relation("activity_created_by", fields: [createdBy], references: [id])
  updated_by_user Users?              @relation("activity_updated_by", fields: [updatedBy], references: [id])
  links           crm_ActivityLinks[]

  @@index([date])
  @@index([type])
  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
  @@index([deletedAt])
}

model crm_ActivityLinks {
  id         String         @id @default(uuid()) @db.Uuid
  activityId String         @db.Uuid
  entityType String
  entityId   String         @db.Uuid
  activity   crm_Activities @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@index([entityType, entityId, activityId])
}

model Boards {
  id                String          @id @default(uuid()) @db.Uuid
  v                 Int             @map("__v")
  description       String
  favourite         Boolean?
  favouritePosition BigInt?
  icon              String?
  position          BigInt?
  title             String
  user              String          @db.Uuid
  visibility        String?
  sharedWith        String[]        @db.Uuid
  createdAt         DateTime?       @default(now())
  createdBy         String?         @db.Uuid
  updatedAt         DateTime?       @updatedAt
  updatedBy         String?         @db.Uuid
  deletedAt         DateTime?
  deletedBy         String?         @db.Uuid
  organization_id   String?         @db.Uuid
  watchers          BoardWatchers[]
  organization      Organization?   @relation(fields: [organization_id], references: [id])
  assigned_user     Users           @relation("assigned_user", fields: [user], references: [id])
  sections          Sections[]

  @@index([user])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([favourite])
  @@index([visibility])
  @@index([createdAt])
  @@index([user, favourite])
  @@index([deletedAt])
  @@index([organization_id])
}

model Employees {
  id     String  @id @default(uuid()) @db.Uuid
  v      Int     @map("__v")
  avatar String
  email  String?
  name   String
  salary BigInt
  status String
}

model ImageUpload {
  id String @id @default(uuid()) @db.Uuid
}

model Documents {
  id                     String                        @id @default(uuid()) @db.Uuid
  v                      Int?                          @map("__v")
  date_created           DateTime?                     @default(now())
  createdAt              DateTime?                     @default(now())
  last_updated           DateTime?                     @updatedAt
  updatedAt              DateTime?                     @updatedAt
  document_name          String
  created_by_user        String?                       @db.Uuid
  createdBy              String?                       @db.Uuid
  description            String?
  document_type          String?                       @db.Uuid
  favourite              Boolean?
  document_file_mimeType String
  document_file_url      String
  status                 String?
  visibility             String?
  tags                   Json?
  key                    String?
  size                   Int?
  assigned_user          String?                       @db.Uuid
  connected_documents    String[]
  document_system_type   DocumentSystemType?           @default(OTHER)
  content_text           String?
  summary                String?
  content_hash           String?
  thumbnail_url          String?
  processing_status      DocumentProcessingStatus      @default(PENDING)
  processing_error       String?
  version                Int                           @default(1)
  parent_document_id     String?                       @db.Uuid
  deletedAt              DateTime?
  deletedBy              String?                       @db.Uuid
  assigned_to_user       Users?                        @relation("assigned_to_user", fields: [assigned_user], references: [id])
  created_by             Users?                        @relation("created_by_user", fields: [created_by_user], references: [id])
  documents_type         Documents_Types?              @relation(fields: [document_type], references: [id])
  parent_document        Documents?                    @relation("DocumentVersions", fields: [parent_document_id], references: [id])
  child_versions         Documents[]                   @relation("DocumentVersions")
  accounts               DocumentsToAccounts[]
  contacts               DocumentsToContacts[]
  crm_accounts_tasks     DocumentsToCrmAccountsTasks[]
  leads                  DocumentsToLeads[]
  opportunities          DocumentsToOpportunities[]
  tasks                  DocumentsToTasks[]
  chunks                 crm_Document_Chunks[]
  embedding_record       crm_Embeddings_Documents?

  @@index([created_by_user])
  @@index([assigned_user])
  @@index([document_type])
  @@index([createdBy])
  @@index([status])
  @@index([visibility])
  @@index([favourite])
  @@index([createdAt])
  @@index([document_system_type])
  @@index([content_hash])
  @@index([parent_document_id])
  @@index([processing_status])
  @@index([deletedAt])
}

model Documents_Types {
  id                 String      @id @default(uuid()) @db.Uuid
  v                  Int         @map("__v")
  name               String
  assigned_documents Documents[]
