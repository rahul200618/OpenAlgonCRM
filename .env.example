# OrvixCRM — Environment Variables
# Copy this file to .env and fill in your values

# ===========================================================================
# DATABASE (Required)
# ===========================================================================
# PostgreSQL 17+ with pgvector extension
DATABASE_URL="postgresql://<username>:<password>@<host>:<port>/orvixcrm?schema=public"

# ===========================================================================
# SUPABASE AUTH (Required)
# ===========================================================================
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ===========================================================================
# APP CONFIGURATION
# ===========================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="OrvixCRM"

# ===========================================================================
# WEBHOOK SECURITY (Optional — secure your webhook endpoints)
# ===========================================================================
# Meta Lead Ads webhook
META_WEBHOOK_VERIFY_TOKEN="your-meta-verify-token"
META_APP_SECRET="your-meta-app-secret"

# Google Lead Form webhook
GOOGLE_WEBHOOK_SECRET="your-google-webhook-key"

# Website form webhook
WEBSITE_WEBHOOK_SECRET="your-website-bearer-token"

# Custom webhook
CUSTOM_WEBHOOK_SECRET="your-custom-bearer-token"
# Optional: JSON map of custom field names
# CUSTOM_FIELD_MAP='{"name":"contact_name","email":"contact_email"}'

# ===========================================================================
# EMAIL SERVICE (Optional)
# ===========================================================================
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_WEBHOOK_SECRET="your-resend-webhook-secret"

# SMTP / IMAP (for built-in email client — requires module_emails feature flag)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASSWORD="your-smtp-password"

# ===========================================================================
# FILE STORAGE (Optional — S3-compatible)
# ===========================================================================
NEXT_PUBLIC_MINIO_ENDPOINT="https://your-minio-host"
MINIO_ENDPOINT="https://your-minio-host"
MINIO_PORT="9000"
MINIO_BUCKET="orvixcrm"
MINIO_USE_SSL="true"
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"

# ===========================================================================
# AI FEATURES (Optional — required for AI enrichment / embeddings)
# ===========================================================================
OPENAI_API_KEY="sk-your-openai-api-key"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"
FIRECRAWL_API_KEY="fc-your-firecrawl-key"
E2B_API_KEY="your-e2b-api-key"

# ===========================================================================
# BACKGROUND JOBS (Optional — Inngest)
# ===========================================================================
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# ===========================================================================
# SECURITY
# ===========================================================================
# Encryption key for API keys stored in DB — generate with: openssl rand -hex 32
EMAIL_ENCRYPTION_KEY="your_64_hex_char_key_here"
CRON_SECRET="your-cron-secret"
