# OPENALGON CRM — Environment Variables
# Copy this file to .env and fill in your values

# ===========================================================================
# DATABASE (Required)
# ===========================================================================
# PostgreSQL 17+ with pgvector extension
DATABASE_URL="postgresql://<username>:<password>@<host>:<port>/openalgoncrm?schema=public"

# ===========================================================================
# BETTER AUTH (Required)
# ===========================================================================
# Generate a secure secret (e.g. `openssl rand -base64 32`)
BETTER_AUTH_SECRET="your-better-auth-secret"

# ===========================================================================
# APP CONFIGURATION
# ===========================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="OPENALGON CRM"

# ===========================================================================
# WEBHOOK SECURITY (Optional — secure your webhook endpoints)
# ===========================================================================
# Meta Lead Ads webhook
META_WEBHOOK_VERIFY_TOKEN="your-meta-verify-token"
META_APP_SECRET="your-meta-app-secret"

# Google Lead Form webhook
GOOGLE_WEBHOOK_SECRET="your-google-webhook-key"

# Website form webhook
WEBSITE_WEBHOOK_SECRET="your-website-bearer-token"

# Custom webhook
CUSTOM_WEBHOOK_SECRET="your-custom-bearer-token"
# Optional: JSON map of custom field names
# CUSTOM_FIELD_MAP='{"name":"contact_name","email":"contact_email"}'

# ===========================================================================
# EMAIL SERVICE (Optional)
# ===========================================================================
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_WEBHOOK_SECRET="your-resend-webhook-secret"

# SMTP / IMAP (for built-in email client — requires module_emails feature flag)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASSWORD="your-smtp-password"

# ===========================================================================
# FILE STORAGE (Optional — S3-compatible)
# ===========================================================================
NEXT_PUBLIC_R2_ENDPOINT="https://your-cloudflare-host"
R2_ENDPOINT="https://your-cloudflare-host"
R2_BUCKET="openalgoncrm"
R2_ACCESS_KEY="your-access-key"
R2_SECRET_KEY="your-secret-key"

# ===========================================================================
# AI FEATURES (Optional — required for AI enrichment / embeddings)
# ===========================================================================
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"
E2B_API_KEY="your-e2b-api-key"

# ===========================================================================
# BACKGROUND JOBS (Optional — Inngest)
# ===========================================================================
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# ===========================================================================
# SECURITY
# ===========================================================================
# Encryption key for API keys stored in DB — generate with: openssl rand -hex 32
EMAIL_ENCRYPTION_KEY="your_64_hex_char_key_here"
CRON_SECRET="your-cron-secret"

# ===========================================================================
# RAZORPAY BILLING (Required for Payments)
# ===========================================================================
RAZORPAY_KEY_ID="rzp_test_xxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"
NEXT_PUBLIC_RAZORPAY_PRO_PLAN_ID="plan_xxxxxx"
NEXT_PUBLIC_RAZORPAY_PROMAX_PLAN_ID="plan_xxxxxx"
